<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controller - Payments</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<style>
    .data-container {
        padding: 24px;
    }

    .data-container+.data-container {
        margin-top: 24px;
    }

    .data-container p {
        font-weight: 600;
        margin-bottom: 8px;
        width: fit-content;
    }

    .data-container p~p {
        font-weight: 400;
        max-width: 100%;
        margin-bottom: 0px;
    }

    p.error {
        background-color: rgba(247, 104, 104, 0.134);
        color: red;
        padding: 8px 16px;
        border-radius: 4px;
    }
</style>

<body>

    <!-- Get All Orders (silent — for order.uuid) -->
    {% parse_json paramsorderslist %}
    {
        "sort_by": "updated_at",
        "sort_order": "DESC",
        "size": 1,
        "page": 1
    }
    {% endparse_json %}
    {% function dataorders = "ecommerce/controller/order/list", params: paramsorderslist %}

    <!-- Get All -->
    {% parse_json paramsgetall %}
    {
        "sort_by": "date_time",
        "sort_order": "DESC",
        "size": 10,
        "page": 1
    }
    {% endparse_json %}
    {% function datagetall = "ecommerce/controller/payment/list", params: paramsgetall %}
    <div class="data-container">
        <p>Get All</p>
        {% if datagetall.message or datagetall.errors %}
        <p class="error">{{ datagetall }}</p>
        {% else %}
        <p>{{ datagetall }}</p>
        {% endif %}
    </div>

    <!-- Get Single -->
    {% function dataget = "ecommerce/controller/payment/get", uuid: datagetall.results[0].uuid %}
    <div class="data-container">
        <p>Get Single</p>
        {% if dataget.message or dataget.errors %}
        <p class="error">{{ dataget }} | Payment UUID: {{ datagetall.results[0].uuid }}</p>
        {% else %}
        <p>{{ dataget }}</p>
        {% endif %}
    </div>

    <!-- Add -->
    {% parse_json paramsadd %}
    {
        "order.uuid": "{{ dataorders.results[0].uuid }}",
        "source": "credit_card",
        "status": "paid",
        "amount": 275.0,
        "notes": "[QA TEST] Controller payment notes",
        "date_time": "2026-04-27T10:00:00Z",
        "payment_gateway_name": "[QA TEST] Manual Gateway",
        "payment_gateway_details": "{\"reference\":\"QA-CTRL-PAY-001\"}",
        "card_last_four_digits": "4242",
        "card_brand": "Visa",
        "card_expiry_month": "12",
        "card_expiry_year": "2028",
        "currency": "USD",
        "payment_method_name": "[QA TEST] Credit Card"
    }
    {% endparse_json %}
    {% function dataadd = "ecommerce/controller/payment/create", params: paramsadd %}
    <div class="data-container">
        <p>Add</p>
        {% if dataadd.message or dataadd.errors %}
        <p class="error">{{ dataadd }}</p>
        {% else %}
        <p>{{ dataadd }}</p>
        {% endif %}
    </div>

    <!-- Update -->
    {% parse_json paramsupdate %}
    {
        "status": "refunded",
        "amount": -275.0,
        "notes": "[QA TEST] Controller payment notes updated - refund processed"
    }
    {% endparse_json %}
    {% function dataupdate = "ecommerce/controller/payment/update", uuid: dataadd.uuid, params: paramsupdate %}
    <div class="data-container">
        <p>Update</p>
        {% if dataupdate.message or dataupdate.errors %}
        <p class="error">{{ dataupdate }} | Payment UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ dataupdate }}</p>
        {% endif %}
    </div>

    <!-- Delete -->
    {% function datadelete = "ecommerce/controller/payment/delete", uuid: dataadd.uuid %}
    <div class="data-container">
        <p>Delete</p>
        {% if datadelete.message or datadelete.errors %}
        <p class="error">{{ datadelete }} | Payment UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ datadelete }}</p>
        {% endif %}
    </div>

</body>

</html>
