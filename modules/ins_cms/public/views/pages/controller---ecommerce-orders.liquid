---
slug: controller---ecommerce-orders
searchable: true
metadata: {
    is_visible_to_search_engines: "true",
    page_name: "Controller - Ecommerce Orders",
    page_title: "Controller - Ecommerce Orders",
}
--- 

<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controller - Orders</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<style>
    .data-container {
        padding: 24px;
    }

    .data-container+.data-container {
        margin-top: 24px;
    }

    .data-container p {
        font-weight: 600;
        margin-bottom: 8px;
        width: fit-content;
    }

    .data-container p~p {
        font-weight: 400;
        max-width: 100%;
        margin-bottom: 0px;
    }

    p.error {
        background-color: rgba(247, 104, 104, 0.134);
        color: red;
        padding: 8px 16px;
        border-radius: 4px;
    }
</style>

<body>

    <!-- Get All Companies (silent — for order_company.uuid) -->
    {% parse_json paramscompanieslist %}
    {
        "sort_by": "updated_at",
        "sort_order": "DESC",
        "size": 1,
        "page": 1
    }
    {% endparse_json %}
    {% function datacompanies = "crm/controller/companies/list", params: paramscompanieslist %}

    <!-- Get All -->
    {% parse_json paramsgetall %}
    {
        "sort_by": "date_time",
        "sort_order": "DESC",
        "size": 10,
        "page": 1
    }
    {% endparse_json %}
    {% function datagetall = "ecommerce/controller/order/list", params: paramsgetall %}
    <div class="data-container">
        <p>Get All</p>
        {% if datagetall.message or datagetall.errors %}
        <p class="error">{{ datagetall }}</p>
        {% else %}
        <p>{{ datagetall }}</p>
        {% endif %}
    </div>

    <!-- Get Single -->
    {% function dataget = "ecommerce/controller/order/get", uuid: datagetall.results[0].uuid %}
    <div class="data-container">
        <p>Get Single</p>
        {% if dataget.message or dataget.errors %}
        <p class="error">{{ dataget }} | Order UUID: {{ datagetall.results[0].uuid }}</p>
        {% else %}
        <p>{{ dataget }}</p>
        {% endif %}
    </div>

    <!-- Add -->
    {% parse_json paramsadd %}
    {
        "order_number": "[QA TEST] ORD-CTRL-001",
        "billing_address_label": "[QA TEST] Billing Address",
        "shipping_address_label": "[QA TEST] Shipping Address",
        "billing_address_1": "100 QA Main St",
        "billing_city": "Metropolis",
        "billing_country_code": "US",
        "billing_postcode": "10001",
        "is_use_crm_billing_address": false,
        "shipping_address_1": "200 QA Delivery Rd",
        "shipping_city": "Gotham",
        "shipping_country_code": "US",
        "shipping_postcode": "20002",
        "is_use_crm_shipping_address": false,
        "freight_supplier_name": "[QA TEST] Speedy Ship",
        "freight_method": "Ground",
        "freight_option": "Insurance",
        "order_reference": "[QA TEST] PO-CTRL-001",
        "order_status": "placed",
        "processing_fee": 100,
        "order_payment_status": "paid",
        "order_shipping_status": "pending_shipment",
        "order_company.uuid": "{{ datacompanies.results[0].uuid }}",
        "notes": "[QA TEST] Controller order notes",
        "date_time": "2026-04-27T10:00:00Z",
        "currency": "USD",
        "subtotal_amount": 250.0,
        "total_tax_amount": 20.0,
        "total_shipping_amount": 15.0,
        "total_discount_amount": 10.0,
        "total_amount": 275.0,
        "order_total": 275.0,
        "total_amount_paid": 275.0,
        "is_scheduled": false,
        "is_recurring": false
    }
    {% endparse_json %}
    {% function dataadd = "ecommerce/controller/order/create", params: paramsadd %}
    <div class="data-container">
        <p>Add</p>
        {% if dataadd.message or dataadd.errors %}
        <p class="error">{{ dataadd }}</p>
        {% else %}
        <p>{{ dataadd }}</p>
        {% endif %}
    </div>

    <!-- Update -->
    {% parse_json paramsupdate %}
    {
        "order_status": "processing",
        "order_payment_status": "paid",
        "order_shipping_status": "shipped",
        "freight_tracking_code": "[QA TEST] QA-TRK-001",
        "notes": "[QA TEST] Controller order notes updated",
        "total_amount": 285.0,
        "order_total": 285.0,
        "total_amount_paid": 285.0
    }
    {% endparse_json %}
    {% function dataupdate = "ecommerce/controller/order/update", uuid: dataadd.uuid, params: paramsupdate %}
    <div class="data-container">
        <p>Update</p>
        {% if dataupdate.message or dataupdate.errors %}
        <p class="error">{{ dataupdate }} | Order UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ dataupdate }}</p>
        {% endif %}
    </div>

    <!-- Delete -->
    {% function datadelete = "ecommerce/controller/order/delete", uuid: dataadd.uuid %}
    <div class="data-container">
        <p>Delete</p>
        {% if datadelete.message or datadelete.errors %}
        <p class="error">{{ datadelete }} | Order UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ datadelete }}</p>
        {% endif %}
    </div>

</body>

</html>
