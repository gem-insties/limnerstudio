--- 

<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controller - Configuration</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<style>
    .data-container {
        padding: 24px;
    }

    .data-container+.data-container {
        margin-top: 24px;
    }

    .data-container p {
        font-weight: 600;
        margin-bottom: 8px;
        width: fit-content;
    }

    .data-container p~p {
        font-weight: 400;
        max-width: 100%;
        margin-bottom: 0px;
    }

    p.error {
        background-color: rgba(247, 104, 104, 0.134);
        color: red;
        padding: 8px 16px;
        border-radius: 4px;
    }
</style>

<body>

    <!-- Get -->
    {% function dataget = "ecommerce/controller/configuration/get" %}
    <div class="data-container">
        <p>Get</p>
        {% if dataget.message or dataget.errors %}
        <p class="error">{{ dataget }}</p>
        {% else %}
        <p>{{ dataget }}</p>
        {% endif %}
    </div>

    <!-- Update -->
    {% parse_json paramsupdate %}
    {
        "measurement_unit": "cm",
        "weight_unit": "kg"
    }
    {% endparse_json %}
    {% function dataupdate = "ecommerce/controller/configuration/update", params: paramsupdate %}
    <div class="data-container">
        <p>Update</p>
        {% if dataupdate.message or dataupdate.errors %}
        <p class="error">{{ dataupdate }}</p>
        {% else %}
        <p>{{ dataupdate }}</p>
        {% endif %}
    </div>

    <!-- Restore — write the initial Get values back so the test leaves no state behind -->
    {% function datarestore = "ecommerce/controller/configuration/update", params: dataget %}
    <div class="data-container">
        <p>Restore</p>
        {% if datarestore.message or datarestore.errors %}
        <p class="error">{{ datarestore }}</p>
        {% else %}
        <p>{{ datarestore }}</p>
        {% endif %}
    </div>

</body>

</html>
