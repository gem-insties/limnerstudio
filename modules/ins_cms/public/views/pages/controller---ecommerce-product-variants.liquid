---
slug: controller---ecommerce-product-variants
searchable: true
metadata: {
    is_visible_to_search_engines: "true",
    page_name: "Controller - Ecommerce Product Variants",
    page_title: "Controller - Ecommerce Product Variants",
}
--- 

<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controller - Product Variants</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<style>
    .data-container {
        padding: 24px;
    }

    .data-container+.data-container {
        margin-top: 24px;
    }

    .data-container p {
        font-weight: 600;
        margin-bottom: 8px;
        width: fit-content;
    }

    .data-container p~p {
        font-weight: 400;
        max-width: 100%;
        margin-bottom: 0px;
    }

    p.error {
        background-color: rgba(247, 104, 104, 0.134);
        color: red;
        padding: 8px 16px;
        border-radius: 4px;
    }
</style>

<body>

    <!-- Get All Products (silent — for product.uuid) -->
    {% parse_json paramsproductslist %}
    {
        "sort_by": "updated_at",
        "sort_order": "DESC",
        "size": 1,
        "page": 1
    }
    {% endparse_json %}
    {% function dataproducts = "ecommerce/controller/product/list", params: paramsproductslist %}

    <!-- Get All -->
    {% parse_json paramsgetall %}
    {
        "sort_by": "updated_at",
        "sort_order": "DESC",
        "size": 10,
        "page": 1
    }
    {% endparse_json %}
    {% function datagetall = "ecommerce/controller/product_variant/list", params: paramsgetall %}
    <div class="data-container">
        <p>Get All</p>
        {% if datagetall.message or datagetall.errors %}
        <p class="error">{{ datagetall }}</p>
        {% else %}
        <p>{{ datagetall }}</p>
        {% endif %}
    </div>

    <!-- Get Single -->
    {% function dataget = "ecommerce/controller/product_variant/get", uuid: datagetall.results[0].uuid %}
    <div class="data-container">
        <p>Get Single</p>
        {% if dataget.message or dataget.errors %}
        <p class="error">{{ dataget }} | Product Variant UUID: {{ datagetall.results[0].uuid }}</p>
        {% else %}
        <p>{{ dataget }}</p>
        {% endif %}
    </div>

    <!-- Add -->
    {% parse_json paramsadd %}
    {
        "product.uuid": "{{ dataproducts.results[0].uuid }}",
        "product_sku": "QA-CTRL-VAR-001",
        "stock_level": 50,
        "regular_price": 29.99,
        "cost_price": 12.0,
        "compare_at_price": 35.0,
        "sale_price": 25.0,
        "is_on_sale": true,
        "is_fixed_tax_amount": false,
        "tax_amount": 0.0,
        "freight_amount": 0.0,
        "is_free_shipping": true,
        "width": 10.0,
        "length": 20.0,
        "height": 5.0,
        "weight": 0.25,
        "product_options": ["{\"product_option_label\":\"Color\",\"product_option_value\":\"Red\"}", "{\"product_option_label\":\"Size\",\"product_option_value\":\"M\"}"]
    }
    {% endparse_json %}
    {% function dataadd = "ecommerce/controller/product_variant/create", params: paramsadd %}
    <div class="data-container">
        <p>Add</p>
        {% if dataadd.message or dataadd.errors %}
        <p class="error">{{ dataadd }}</p>
        {% else %}
        <p>{{ dataadd }}</p>
        {% endif %}
    </div>

    <!-- Update -->
    {% parse_json paramsupdate %}
    {
        "product_sku": "QA-CTRL-VAR-001-UPD",
        "stock_level": 45,
        "regular_price": 30.99,
        "sale_price": 26.0,
        "is_on_sale": true
    }
    {% endparse_json %}
    {% function dataupdate = "ecommerce/controller/product_variant/update", uuid: dataadd.uuid, params: paramsupdate %}
    <div class="data-container">
        <p>Update</p>
        {% if dataupdate.message or dataupdate.errors %}
        <p class="error">{{ dataupdate }} | Product Variant UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ dataupdate }}</p>
        {% endif %}
    </div>

    <!-- Delete -->
    {% function datadelete = "ecommerce/controller/product_variant/delete", uuid: dataadd.uuid %}
    <div class="data-container">
        <p>Delete</p>
        {% if datadelete.message or datadelete.errors %}
        <p class="error">{{ datadelete }} | Product Variant UUID: {{ dataadd.uuid }}</p>
        {% else %}
        <p>{{ datadelete }}</p>
        {% endif %}
    </div>

</body>

</html>
