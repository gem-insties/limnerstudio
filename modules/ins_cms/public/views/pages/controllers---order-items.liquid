<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Controller - Ecommerce Order Items</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<style>
    .data-container {
        padding: 24px;
    }

    .data-container+.data-container {

        margin-top: 24px;
    }

    .data-container p {
        font-weight: 600;
        margin-bottom: 8px;
        width: fit-content;
    }

    .data-container p~p {
        font-weight: 400;
        max-width: 100%;
        margin-bottom: 0px;
    }

    p.error {
        background-color: rgba(247, 104, 104, 0.134);
        color: red;
        padding: 8px 16px;
        border-radius: 4px;
    }
</style>

<body>
    <!-- Navbar -->
    <nav class="flex justify-between items-center p-6 bg-white shadow">
        <h1 class="text-2xl font-bold text-blue-600">MyBrand</h1>
        <div>
            <a href="#features" class="px-4 text-gray-700 hover:text-blue-600">Features</a>
            <a href="#about" class="px-4 text-gray-700 hover:text-blue-600">About</a>
            <a href="#contact" class="px-4 text-gray-700 hover:text-blue-600">Contact</a>
            <a href="#signup" class="ml-4 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Sign Up</a>
        </div>
    </nav>

    <!-- Update -->
    {% parse_json paramsupdate %}
    {
    "order_item_image":
    "https://cdn.staging.oregon.platform-os.com/instances/8697/property_uploads/modules/insites_ecommerce/product/product_image/175334d3-8051-4680-af2f-9646da463b18/product_2.jpg",
    "order_item_name": "API Updatedx",
    "sku": "API-UPDATED-SKU",
    "quantity": 100,
    "unit_price": 200,
    "item_tax": 300,
    "tax_amount": 300,
    "line_item_total": 50000,
    "line_item_tax": 30000,
    "item_price": 500,
    "is_fixed_tax_amount": true,
    "order.uuid": "497e6c29-824a-4d16-a5a8-4b68e036b813",
    "product.uuid": "2c819ee6-bb8d-4a14-a138-f05973136dff",
    "product_variant.uuid": "6963f96f-97eb-45a7-aa0e-afc4dfb4639c"
    }
    {% endparse_json %}
    {% function dataupdate = "ecommerce/controller/order_items/update", uuid: "764f30bd-53ef-497f-8f70-8334bb6b26f4", params:paramsupdate %}
    <div class="data-container">
        <p>Update</p>
        {% if dataupdate.errors %}
        <p class="error"> {{ dataupdate }} | Order Item UUID: 764f30bd-53ef-497f-8f70-8334bb6b26f4</p>
        {% else %}
        <p>{{ dataupdate }}</p>
        {% endif %}
    </div>

    <!-- Footer -->
    <footer class="py-6 text-center bg-gray-900 text-gray-400">
        <p>© 2025 MyBrand. All rights reserved.</p>
    </footer>

</body>

</html>