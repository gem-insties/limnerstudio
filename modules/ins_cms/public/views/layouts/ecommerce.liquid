---
metadata: {
    created_by: "QA Console",
    layout_name: "Ecommerce",
    last_updated_by: "QA Insites",
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
    <!-- Ecommerce SEO fields -->
  	{% assign slug = current_url | split: '/ecommerce-products/' | last %}
	{% if current_url contains '/ecommerce-products.html' %}
    	{%- include 'modules/insites_cms/seo' -%}
	{% else %}
    	<!-- Ecommerce Product Details -->
    	{%- include 'modules/insites_ecommerce/seo', type: 'product', slug: slug -%}
	{% endif %}
    
 	<!-- IMPORT GLOBALS -->
  	{%- include "modules/insites_cms/globals" -%}
  
  	<!-- Foundation CDN -->
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/foundation-sites@6.8.1/dist/css/foundation.min.css" crossorigin="anonymous">
	<script src="https://cdn.jsdelivr.net/npm/foundation-sites@6.8.1/dist/js/foundation.min.js" crossorigin="anonymous"></script>
</head>
<body>
  <h1>Layout Content</h1>
  {{ context.exports.data.item.slug }}
  	{{ content_for_layout }}
</body>
</html>